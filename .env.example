# ──────────────────────────────────────────────────────────────────────────
# Client (VITE_*) environment — these are bundled into the browser build.
# ONLY put values here that are safe to expose publicly: the Supabase anon key
# (protected by RLS) and the CFBD key (read-only, free tier, no cost risk).
#
# The Resend key is NOT a client var — it lives as a Supabase Edge Function
# secret and is never shipped to the browser. See the Phase 3 runbook.
# ──────────────────────────────────────────────────────────────────────────

# Supabase (public anon key — safe to expose, guarded by RLS)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# CollegeFootballData API (read-only, free tier — get a key at https://collegefootballdata.com/)
VITE_CFBD_API_KEY=your_cfbd_api_key

# Optional: Sportradar API (only if used client-side)
VITE_SPORTRADAR_API_KEY=your_sportradar_api_key

# ──────────────────────────────────────────────────────────────────────────
# Server-side secrets — DO NOT put these in client (.env / VITE_*) files.
# Set them as Supabase Edge Function secrets instead:
#   supabase secrets set RESEND_API_KEY=...      # used by send-email
#   supabase secrets set CFBD_API_KEY=...        # used by live-score-updater (cron)
#
# For running DDL / admin scripts locally (kept out of git via .gitignore):
#   SUPABASE_SERVICE_ROLE_KEY=...
#   SUPABASE_DB_URL=postgresql://...
# ──────────────────────────────────────────────────────────────────────────
