# ──────────────────────────────────────────────────────────────────────────
# Client (VITE_*) environment — these are bundled into the browser build.
# ONLY put values here that are safe to expose publicly (e.g. the Supabase
# anon key, which is protected by Row Level Security).
#
# Secret API keys (Resend, CFBD) are NOT client vars. They live as secrets in
# Supabase Edge Functions and are never shipped to the browser. See README /
# the Phase 3 runbook.
# ──────────────────────────────────────────────────────────────────────────

# Supabase (public anon key — safe to expose, guarded by RLS)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: Sportradar API (only if used client-side)
VITE_SPORTRADAR_API_KEY=your_sportradar_api_key

# ──────────────────────────────────────────────────────────────────────────
# Server-side secrets — DO NOT put these in client (.env / VITE_*) files.
# Set them as Supabase Edge Function secrets instead:
#   supabase secrets set RESEND_API_KEY=...      # used by send-email
#   supabase secrets set CFBD_API_KEY=...        # used by live-score-updater / cfbd proxy
#
# For running DDL / admin scripts locally (kept out of git via .gitignore):
#   SUPABASE_SERVICE_ROLE_KEY=...
#   SUPABASE_DB_URL=postgresql://...
# ──────────────────────────────────────────────────────────────────────────
